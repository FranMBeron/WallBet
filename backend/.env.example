APP_NAME=WallBet
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=wallbet
DB_USERNAME=wallbet
DB_PASSWORD=wallbet
# DB_SSLMODE=require  # Required for Neon (staging/prod). Remove or set to 'disable' for local Docker.

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# WALLBIT_ENCRYPTION_KEY must be a 64-char hex string (32 bytes).
# Generate with: php -r "echo bin2hex(random_bytes(32));"
# WARNING: IMMUTABLE once data exists in wallbit_keys. Changing this key
# will make all stored API keys unreadable. Never rotate without migrating data.
WALLBIT_ENCRYPTION_KEY=

WALLBIT_API_BASE_URL=https://api.wallbit.io/api/public/v1

# Sanctum stateful domains (used for future SPA/cookie mode)
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000

# Test database (used by phpunit)
# DB_TEST_DATABASE=wallbet_test
