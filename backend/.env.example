APP_NAME=WallBet
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_DEMO_MODE=true

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=wallbet
DB_USERNAME=wallbet
DB_PASSWORD=wallbet
# For Neon (production): use DB_URL or set DB_SSLMODE=require
# DB_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require
# DB_SSLMODE=require

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000

WALLBIT_ENCRYPTION_KEY=
WALLBIT_API_BASE_URL=https://api.wallbit.io/api/public/v1

LOG_CHANNEL=stack
LOG_LEVEL=debug

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
